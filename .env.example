# ── Buffet Backend — Environment Variables ──────────────────────────────────

# Required: SQLite database path
DATABASE_URL=sqlite:./db/buffet.db

# Optional: TimescaleDB / PostgreSQL connection string
# Defaults to local Postgres if not set
TSDB_URL=postgres://postgres:postgres@localhost:5432/buffet_timeseries

# Optional: Server bind address
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# Optional: Actor system tuning
ACTOR_MAILBOX_SIZE=1000
ACTOR_TIMEOUT_MS=5000

# Optional: Logging level (trace, debug, info, warn, error)
RUST_LOG=info

# Optional: Set to any value to enable test logging output
# TEST_LOG=1
